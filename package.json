{
  "name": "hidockskill",
  "version": "1.0.0",
  "description": "100% local meeting transcription, summarization, and visualization for HiDock USB recorders (Moonshine ASR + Ollama LLM)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "probe:lab": "node research/protocol_lab.mjs",
    "probe:live": "node research/hidock_live_probe.mjs",
    "meetings:sync": "npm run build && node dist/cli/meetingsSync.js",
    "usb:watch": "npm run build && node dist/cli/usbWatch.js",
    "galaxy": "npm run build && node dist/cli/galaxyDashboard.js",
    "galaxy:open": "npm run build && node dist/cli/galaxyDashboard.js --open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "usb": "^2.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
